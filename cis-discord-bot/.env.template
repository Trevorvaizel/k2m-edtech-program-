# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_server_id
# Keep false in active development to avoid duplicate global+guild commands.
SYNC_GLOBAL_COMMANDS=false
CHANNEL_THINKING_LAB=channel_id
CHANNEL_THINKING_SHOWCASE=channel_id
CHANNEL_FACILITATOR_DASHBOARD=channel_id
# Required for Trevor-only admin observability commands.
TREVOR_DISCORD_ID=your_trevor_discord_user_id
# Development override only; keep false in production.
ALLOW_INSECURE_ADMIN=false

# Weekly Channel Mapping (for daily prompt posting - Story 2.1)
# Map week numbers to Discord channel IDs
CHANNEL_WEEK_1=channel_id
CHANNEL_WEEK_2_3=channel_id
CHANNEL_WEEK_4_5=channel_id
CHANNEL_WEEK_6_7=channel_id
CHANNEL_WEEK_8=channel_id

# AI Provider Routing
# Use zhipu now, switch to anthropic later without code changes.
AI_PROVIDER=zhipu

# zhipu / GLM (OpenAI-compatible)
ZHIPU_API_KEY=your_zhipu_api_key_here
LLM_MODEL=glm-4.7
# Optional: override endpoint if needed
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# OpenAI / GPT (set AI_PROVIDER=openai)
# OPENAI_API_KEY=your_openai_api_key_here
# Optional: custom/proxy endpoint
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional OpenAI default model key (alternative to LLM_MODEL)
# OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude API (future swap target)
ANTHROPIC_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5-20250514
ENABLE_PROMPT_CACHING=true

# Cost Controls
MAX_INTERACTIONS_PER_DAY=50
DAILY_BUDGET_ALERT=10.00
WEEKLY_BUDGET_CAP=50.00

# Cohort Configuration
COHORT_START_DATE=2026-02-01
COHORT_DURATION_WEEKS=8

# Feature Flags
ENABLE_NATURAL_LANGUAGE_FALLBACK=true
ENABLE_ARTIFACT_TRACKING=true
ENABLE_TREVOR_NOTIFICATIONS=true
TREVOR_NOTIFICATION_WEBHOOK=https://hooks.slack.com/...

# Development
DEBUG=false
LOG_LEVEL=INFO
