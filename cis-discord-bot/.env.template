# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_server_id
# Keep false in active development to avoid duplicate global+guild commands.
SYNC_GLOBAL_COMMANDS=false
CHANNEL_THINKING_LAB=channel_id
CHANNEL_THINKING_SHOWCASE=channel_id
CHANNEL_FACILITATOR_DASHBOARD=channel_id
CHANNEL_MODERATION_LOGS=channel_id
# Required for Trevor-only admin observability commands.
TREVOR_DISCORD_ID=your_trevor_discord_user_id
# Development override only; keep false in production.
ALLOW_INSECURE_ADMIN=false

# Weekly Channel Mapping (for daily prompt posting - Story 2.1)
# Map week numbers to Discord channel IDs
CHANNEL_WEEK_1=channel_id
CHANNEL_WEEK_2_3=channel_id
CHANNEL_WEEK_4_5=channel_id
CHANNEL_WEEK_6_7=channel_id
CHANNEL_WEEK_8=channel_id

# AI Provider Routing
# Active runtime provider for this repo is OpenAI.
# Swap providers without code changes via AI_PROVIDER: openai | anthropic | zhipu
AI_PROVIDER=openai

# OpenAI / GPT (active)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
# Optional: custom/proxy endpoint
# OPENAI_BASE_URL=https://api.openai.com/v1
# Backward-compat model fallback used by some tooling
LLM_MODEL=gpt-4.1-mini

# Anthropic Claude API (future swap target)
ANTHROPIC_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5-20250514
ENABLE_PROMPT_CACHING=true

# zhipu / GLM (optional fallback, OpenAI-compatible)
# ZHIPU_API_KEY=your_zhipu_api_key_here
# GLM_MODEL=glm-4.7
# Optional: override endpoint if needed
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Cost Controls
MAX_INTERACTIONS_PER_DAY=50
DAILY_BUDGET_ALERT=10.00
WEEKLY_BUDGET_CAP=50.00

# Cohort Configuration
COHORT_START_DATE=2026-02-01
COHORT_DURATION_WEEKS=8

# Parent Email System (Task 4.6)
# Provider keys: configure at least one in production
BREVO_API_KEY=
# Optional override for Brevo API base URL
BREVO_BASE_URL=https://api.brevo.com/v3
SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
EMAIL_FROM=trevor@k2mlabs.com
EMAIL_FROM_NAME=Trevor from K2M
PARENT_EMAIL_FROM=trevor@k2mlabs.com
PARENT_EMAIL_FROM_NAME=Trevor from K2M
PARENT_EMAIL_REPLY_TO=trevor@k2mlabs.com
# Optional visual customization for parent email templates
PARENT_EMAIL_LOGO_URL=
# Optional local SVG path override (defaults to k2m-landing/public/k2m-logo.svg when available)
PARENT_EMAIL_LOGO_SVG_PATH=
# Optional logo render size in px (applies to URL image or inline SVG)
PARENT_EMAIL_LOGO_SIZE_PX=88
PARENT_EMAIL_CTA_URL=https://discord.com
PARENT_EMAIL_SOCIAL_INSTAGRAM_URL=
PARENT_EMAIL_SOCIAL_X_URL=
PARENT_EMAIL_SOCIAL_WHATSAPP_URL=
PARENT_EMAIL_SOCIAL_DISCORD_URL=

# Optional delivery controls
EMAIL_DRY_RUN=false
PARENT_EMAIL_RETRY_DELAYS_SECONDS=60,300,900

# Unsubscribe links and lightweight endpoint
PARENT_UNSUBSCRIBE_BASE=https://k2m-edtech.program/parent/unsubscribe
ENABLE_PARENT_UNSUBSCRIBE_SERVER=true
PARENT_UNSUBSCRIBE_HOST=0.0.0.0
PARENT_UNSUBSCRIBE_PORT=8080
PARENT_UNSUBSCRIBE_PATH=/parent/unsubscribe

# Feature Flags
ENABLE_NATURAL_LANGUAGE_FALLBACK=true
ENABLE_ARTIFACT_TRACKING=true
ENABLE_TREVOR_NOTIFICATIONS=true
TREVOR_NOTIFICATION_WEBHOOK=https://hooks.slack.com/...

# Development
DEBUG=false
LOG_LEVEL=INFO
