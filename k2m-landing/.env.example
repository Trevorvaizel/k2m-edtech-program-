# K2M Landing Page Environment Variables
# Task 7.1: Enrollment Form Integration

# API endpoint for /api/interest (cis-discord-bot InterestAPIServer)
# In production, this should point to your Railway deployment URL
# Example: https://k2m-cis-bot.railway.app/api/interest
VITE_INTEREST_API_URL=http://localhost:8081/api/interest

# API endpoint for /api/enroll
VITE_ENROLL_API_URL=http://localhost:8081/api/enroll

# API endpoint for /api/mpesa-submit
VITE_MPESA_SUBMIT_API_URL=http://localhost:8081/api/mpesa-submit
